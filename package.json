{
  "name": "creator-vault",
  "version": "1.0.0",
  "description": "`A TypeScript CLI for collecting YouTube channel, video, and transcript data into SQLite.`",
  "bin": {
    "et": "./dist/run.js"
  },
  "directories": {
    "lib": "src",
    "bin": "bin"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup-node",
    "build:watch": "tsup-node --watch",
    "link": "npm link",
    "clean": "rimraf dist",
    "commit": "cz",
    "commitlint": "commitlint --edit",
    "compile": "tsc",
    "db:migrate": "# ts-node ./src/db/migrate.ts",
    "db:reset": "cp -f src/db/db.sqlite src/db/db.sqlite.bak && sqlite3 src/db/db.sqlite < src/db/schema.sql",
    "db:seed": "find src/db/seeds -maxdepth 1 -name \"*.sql\" | sort | xargs -I {} sh -c 'sqlite3 src/db/db.sqlite \".read {}\"'",
    "db:dump:schema": "ts-node ./src/db/scripts/db-dump.ts schema",
    "db:dump:table": "ts-node ./src/db/scripts/db-dump.ts table",
    "db:dump:data": "ts-node ./src/db/scripts/db-dump.ts data",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "ts-node -r tsconfig-paths/register ./bin/run.ts",
    "start:node": "node ./bin/run",
    "test": "jest",
    "test:services": "jest src/services",
    "test:commands": "jest src/commands",
    "test:lib": "jest src/lib",
    "test:watch": "jest --watchAll",
    "prepare": "husky",
    "release": "semantic-release"
  },
  "keywords": [
    "typescript",
    "starter",
    "cli",
    "bootstrap"
  ],
  "author": "Andrey Kucherenko <kucherenko.andrey@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@jest/globals": "^29.7.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "@types/prompts": "^2.4.9",
    "@types/signale": "^1.4.7",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.7",
    "semantic-release": "^23.1.1",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "consola": "^3.2.3",
    "dotenv": "^16.4.5",
    "giget": "^1.2.3",
    "picocolors": "^1.0.1",
    "prompts": "^2.4.2",
    "yargs": "^17.7.2",
    "youtube-dl-exec": "^3.1.8",
    "youtube-transcript-plus": "^2.0.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
